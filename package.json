{
  "name": "neural-cli-orchestrator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "NCO Backend — 9 AI agents working as one team",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "tsx src/worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration:phase1-2": "tsx tests/phase1-2-verify.ts",
    "test:integration:phase3": "tsx tests/phase3-verify.ts",
    "test:integration:agent": "tsx tests/agent-integration.ts",
    "test:integration:team": "tsx tests/team-work.ts",
    "test:integration:full": "tsx tests/full-integration.ts",
    "test:integration:comprehensive": "tsx tests/nco-comprehensive-test.ts",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "migrate": "tsx src/storage/migrations.ts",
    "ollama:start": "bash cli-installs/ollama-ctl.sh start",
    "ollama:stop": "bash cli-installs/ollama-ctl.sh stop",
    "ollama:status": "bash cli-installs/ollama-ctl.sh status",
    "vllm:start": "bash cli-installs/ollama-ctl.sh start",
    "vllm:stop": "bash cli-installs/ollama-ctl.sh stop",
    "vllm:status": "bash cli-installs/ollama-ctl.sh status"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@discordjs/rest": "^2.6.1",
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@google/generative-ai": "^0.24.1",
    "@mendable/firecrawl-js": "^4.18.2",
    "@notionhq/client": "^5.22.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "better-sqlite3": "^12.8.0",
    "bullmq": "^5.73.3",
    "chokidar": "^4.0.3",
    "discord-api-types": "^0.38.48",
    "dotenv": "^17.4.1",
    "duck-duck-scrape": "^2.2.7",
    "eventemitter3": "^5.0.4",
    "execa": "^9.6.1",
    "fastify": "^5.8.4",
    "handlebars": "^4.7.9",
    "imapflow": "^1.4.0",
    "ioredis": "^5.10.1",
    "mem0ai": "^3.0.12",
    "msgpackr": "^1.11.5",
    "nanoid": "^5.1.7",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^9.0.0",
    "openai": "^6.34.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/handlebars": "^4.0.40",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
