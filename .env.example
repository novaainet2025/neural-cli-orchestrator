# ═══════════════════════════════════════════
# NCO Backend Environment Configuration
# Copy to .env and fill in your keys
# ═══════════════════════════════════════════

PORT=6200
WS_PORT=6201
NODE_ENV=development
DATABASE_PATH=./db/nco.db
REDIS_URL=redis://127.0.0.1:6379
STATE_FILE_PATH=./db/worker-state.json
DASHBOARD_URL=http://localhost:6260
PROJECT_DIR=/mnt/d/NCO-Dashboard
NCO_API_TOKEN=nco_secret_key_change_me_in_production

ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Gemini 14-key rotation (콤마로 구분, 한 줄에 입력)
GEMINI_API_KEYS=AIzaSyXXX,AIzaSyYYY,AIzaSyZZZ

# OpenRouter Free Tier (콤마로 구분, 리밋 시 자동 롤링)
OPENROUTER_API_KEYS=sk-or-v1-XXX,sk-or-v1-YYY

VLLM_BASE_URL=http://localhost:8000/v1
WORKER_CONCURRENCY=4
WORKER_VLLM_CONCURRENCY=1
WORKER_RATE_LIMIT_RPM=20
WORKER_VLLM_RATE_LIMIT_RPM=5
