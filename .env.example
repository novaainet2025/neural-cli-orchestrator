# ═══════════════════════════════════════════
# NCO Backend Environment Configuration
# Copy to .env and fill in your keys
# ═══════════════════════════════════════════

PORT=6200
WS_PORT=6201
NODE_ENV=development
DATABASE_PATH=./db/nco.db
REDIS_URL=redis://127.0.0.1:6379
STATE_FILE_PATH=./db/worker-state.json
DASHBOARD_URL=http://localhost:6260
PROJECT_DIR=/mnt/d/NCO-Dashboard
NCO_API_TOKEN=nco_secret_key_change_me_in_production

ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Gemini 14-key rotation (콤마로 구분, 한 줄에 입력)
GEMINI_API_KEYS=AIzaSyXXX,AIzaSyYYY,AIzaSyZZZ

# OpenRouter Free Tier (콤마로 구분, 리밋 시 자동 롤링)
OPENROUTER_API_KEYS=sk-or-v1-XXX,sk-or-v1-YYY

# vLLM — Gemma 4 26B (NVFP4, Active 4B MoE, RTX 4090)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=gemma-4-26B-A4B-it-NVFP4
VLLM_MODEL_PATH=/mnt/d/llm-models/vllm/gemma-4-26B-A4B-it-NVFP4
VLLM_NVFP4_GEMM_BACKEND=marlin

# Ollama (Validator) — WSL에서 Windows Ollama: 게이트웨이 IP (예: ip route | awk '/default/{print $3}')
# 설정 시 ai-providers.json 의 localhost:11434 가 이 주소로 대체됨 (상태바 Ol 표시에도 영향)
# OLLAMA_BASE_URL=http://172.28.112.1:11434

# 동시성/RPM은 config/ai-providers.json (concurrency/rateLimitRpm)이 단일소스
